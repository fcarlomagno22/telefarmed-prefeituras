NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173
# URL pública do frontend (links de e-mail, QR Code). Padrão: primeiro valor de CORS_ORIGIN.
PUBLIC_APP_URL=http://localhost:5173
# Para testar links do e-mail no celular na mesma rede Wi‑Fi, use o IP da máquina:
# PUBLIC_APP_LAN_URL=http://192.168.1.103:5173
PUBLIC_APP_LAN_URL=
# Portal do profissional (links de plantão no e-mail, agenda após aceite). Padrão: https://profissional.telefarmed.com.br
# Use a URL pública mesmo em dev se o SMTP enviar e-mails reais para médicos.
PROFISSIONAL_PORTAL_URL=https://profissional.telefarmed.com.br
# Portal da prefeitura (link no e-mail de relatórios automatizados).
# Preferencial: https://{slug-entidade}.telefarmed.com.br/relatorios (via buildGestaoUrl no backend).
# Legado local: PUBLIC_APP_URL/prefeitura/relatorios
PREFEITURA_PORTAL_URL=
COOKIE_SECURE=false

# Token da conta Supabase (mesmo do MCP): https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=fsyiqpueswytvxgrlibq
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
# Rode: npm run setup:supabase-env
SUPABASE_SERVICE_ROLE_KEY=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# LiveKit Cloud (teleconsulta) — https://cloud.livekit.io
LIVEKIT_URL=wss://seu-projeto.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# SMTP (recuperação de senha UBT e demais e-mails transacionais)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Opcional — padrão: Telefarmed <SMTP_USER>
SMTP_FROM=

# Cron (Vercel + testes manuais) — rotas GET /api/v1/internal/cron/*
# Gere: openssl rand -hex 32
# Na Vercel: mesmo valor em CRON_SECRET (a plataforma envia Authorization: Bearer ...)
CRON_SECRET=

# Tenants por subdomínio ({slug}.telefarmed.com.br)
PUBLIC_ROOT_DOMAIN=telefarmed.com.br
CORS_ALLOW_TENANT_ORIGINS=true

# API ICD da OMS (busca de CID no atestado) — https://icd.who.int/icdapi
WHO_ICD_CLIENT_ID=
WHO_ICD_CLIENT_SECRET=

ADMIN_MASTER_CPF=22652204858
ADMIN_MASTER_NAME=Fernando Carlomagno
ADMIN_MASTER_EMAIL=
ADMIN_MASTER_PASSWORD=
