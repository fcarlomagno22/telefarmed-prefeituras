{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/v1/internal/cron/pos-consulta",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/v1/internal/cron/prefeitura-relatorios",
      "schedule": "*/15 * * * *"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "backend/dist/**",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/acompanhar/:token",
      "has": [{ "type": "host", "value": "prefeitura.telefarmed.com.br" }],
      "destination": "https://seguranca.telefarmed.com.br/:token",
      "permanent": true
    },
    {
      "source": "/:token",
      "has": [{ "type": "host", "value": "ca.telefarmed.com.br" }],
      "destination": "https://seguranca.telefarmed.com.br/:token",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "admin.telefarmed.com.br" }],
      "destination": "/login",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "prefeitura.telefarmed.com.br" }],
      "destination": "/login",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "profissional.telefarmed.com.br" }],
      "destination": "/login",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "ubt.telefarmed.com.br" }],
      "destination": "/login",
      "permanent": false
    }
  ]
}
