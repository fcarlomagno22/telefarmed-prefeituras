{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "backend/dist/**",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "admin.telefarmed.com.br" }],
      "destination": "/login",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "prefeitura.telefarmed.com.br" }],
      "destination": "/login",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "profissional.telefarmed.com.br" }],
      "destination": "/login",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "ubt.telefarmed.com.br" }],
      "destination": "/login",
      "permanent": false
    }
  ]
}
