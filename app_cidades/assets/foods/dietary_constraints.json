{
  "version": "1.0.0",
  "locale": "pt-BR",
  "file": "dietary_constraints.json",
  "engine_mode": "deterministic",
  "runtime_ai_generation": false,
  "description": "Mapeamento de restricoes alimentares, doencas, intolerancias e preferencias do wizard para regras deterministicas de inclusao, exclusao, penalizacao e limites diarios por tags.",
  "clinical_validation": {
    "status": "requires_nutritionist_review",
    "note": "Este arquivo nao substitui avaliacao profissional. Regras clinicas, limites e conflitos devem ser validados por nutricionista responsavel antes de uso assistencial."
  },
  "wizard_mapping": {
    "input_fields": {
      "diseases": {
        "type": "array",
        "maps_to": "constraints.diseases"
      },
      "intolerances": {
        "type": "array",
        "maps_to": "constraints.intolerances"
      },
      "dietaryPreferences": {
        "type": "array",
        "maps_to": "constraints.dietaryPreferences"
      }
    },
    "normalization": {
      "case": "lowercase",
      "trim": true,
      "remove_accents": true,
      "replace_spaces_with": "_",
      "unknown_value_action": "ignore_and_log"
    }
  },
  "rule_semantics": {
    "exclude_tags": "Alimentos com qualquer uma dessas tags nao devem entrar no plano, salvo regra explicitamente marcada como relaxavel.",
    "require_tags": "O plano deve priorizar pelo menos uma quantidade minima de alimentos com essas tags ao longo do dia ou da semana.",
    "penalize_tags": "Alimentos com essas tags permanecem elegiveis, mas recebem penalidade no scoring.",
    "max_per_day": "Limites diarios por tag. Valor 0 significa nao usar no dia; null significa sem limite especifico neste arquivo.",
    "conflict_resolution_order": [
      "medical_allergy_or_celiac_exclusion",
      "ethical_or_religious_preference",
      "disease_specific_exclusion",
      "intolerance_exclusion",
      "dietary_preference",
      "scoring_penalty"
    ],
    "merge_strategy": {
      "exclude_tags": "union",
      "require_tags": "union_after_removing_conflicts_with_exclude_tags",
      "penalize_tags": "union_after_removing_conflicts_with_exclude_tags",
      "max_per_day": "use_most_restrictive_numeric_limit"
    }
  },
  "global_defaults": {
    "exclude_tags": [],
    "require_tags": [
      "minimally_processed",
      "whole_food"
    ],
    "penalize_tags": [
      "ultraprocessed",
      "deep_fried",
      "high_sugar",
      "high_sodium",
      "high_saturated_fat"
    ],
    "max_per_day": {
      "sugary_drink": 0,
      "ultraprocessed": 1,
      "deep_fried": 1,
      "dessert": 1
    }
  },
