{
  "version": "1.0.0",
  "locale": "pt-BR",
  "file": "menu_generation_rules.json",
  "engine_mode": "deterministic",
  "runtime_ai_generation": false,
  "description": "Regras deterministicas para montagem, pontuacao, repeticao, preferencias textuais e fallback do motor de cardapios Telefarmed.",
  "clinical_validation": {
    "status": "requires_nutritionist_review",
    "note": "Regras iniciais de geracao. Devem ser revisadas por nutricionista antes de uso assistencial."
  },
  "deterministic_seed": {
    "enabled": true,
    "seed_inputs": [
      "user_id",
      "plan_start_date",
      "objective",
      "target_kcal",
      "dietary_constraints_hash",
      "liked_foods_hash",
      "avoided_foods_hash"
    ],
    "hash_algorithm": "sha256",
    "same_inputs_same_menu": true,
    "shuffle_strategy": "seeded_weighted_shuffle"
  },
  "calorie_distribution_by_slot": {
    "default": {
      "breakfast": 20,
      "morning_snack": 8,
      "lunch": 32,
      "afternoon_snack": 10,
      "dinner": 25,
      "basket": 5
    },
    "by_objective": {
      "weight_loss": {
        "breakfast": 22,
