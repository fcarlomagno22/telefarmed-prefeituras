  "purpose": {
    "objective": "Definir elegibilidade, informante permitido e ajustes interpretativos por idade.",
    "clinical_use": "Controla quem pode responder, bloqueia aplicação fora da faixa e limita confiança interpretativa conforme idade e tipo de informante.",
    "priority_note": "Regras de idade e consentimento devem ser aplicadas antes do cálculo de score e da classificação final."
  },
