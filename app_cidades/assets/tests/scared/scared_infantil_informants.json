{
  "metadata": {
    "module": "scared_infantil",
    "file": "scared_infantil_informants.json",
    "version": "1.0.0",
    "locale": "pt-BR",
    "instrument_code": "SCARED",
    "instrument_full_name": "Screen for Child Anxiety Related Disorders",
    "instrument_authors_reference": "Birmaher et al., 1997",
    "instrument_item_count": 41,
    "timeframe": "ultimos_3_meses",
    "age_range_years": {
      "min": 8,
      "max": 17
    },
    "parent_proxy_age_range_years": {
      "min": 4,
      "max": 7
    },
    "diagnostic_disclaimer": "Este rastreio não diagnostica transtorno de ansiedade nem qualquer outra condição. Organiza sinais compatíveis e orienta encaminhamento.",
    "depends_on": [
      "scared_infantil_questions.json",
      "scared_infantil_functional_impairment.json",
      "scared_infantil_red_flags.json",
      "scared_infantil_differential_screening.json",
      "scared_infantil_cutoffs.json",
      "scared_infantil_age_rules.json"
    ]
  },
  "purpose": {
    "objective": "Definir quem pode responder, iniciar a triagem, aceitar consentimento, complementar informações escolares e influenciar a confiança interpretativa.",
    "clinical_use": "Organiza informantes sem misturar automaticamente respostas de criança/adolescente, responsável e professor.",
    "priority_note": "Consentimento válido e regras de idade devem ser verificados antes de aceitar respostas."
  },
  "respondent_ids": [
    "crianca_adolescente",
    "responsavel",
    "professor"
  ],
  "informant_types": [
