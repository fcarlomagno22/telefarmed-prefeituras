  "eligibility_questions_for_informant": [
    {
      "id": "informant_relationship",
      "label": "Qual sua relação com a criança/adolescente?",
      "type": "single_choice",
      "required": true,
      "options_from": "informant_types"
    },
    {
      "id": "has_regular_contact",
      "label": "Você convive ou observa essa criança/adolescente com frequência?",
      "type": "single_choice",
      "required": true,
      "answers": [
        {
          "label": "Sim, quase todos os dias",
          "value": "daily",
          "eligible": true
        },
        {
          "label": "Sim, algumas vezes por semana",
          "value": "weekly",
          "eligible": true
        },
        {
          "label": "Poucas vezes por mês",
          "value": "monthly",
          "eligible": "complementar"
        },
        {
          "label": "Raramente",
          "value": "rarely",
          "eligible": false
        }
      ]
    },
    {
      "id": "observation_period",
      "label": "Há quanto tempo você observa essa criança/adolescente nessa rotina?",
      "type": "single_choice",
      "required": true,
      "answers": [
        {
          "label": "Menos de 4 semanas",
          "value": "less_than_4_weeks",
          "eligible": "limited_confidence"
        },
        {
          "label": "1 a 3 meses",
          "value": "1_to_3_months",
          "eligible": true
        },
        {
          "label": "Mais de 3 meses",
          "value": "more_than_3_months",
          "eligible": true
        }
      ]
    },
    {
      "id": "responding_context",
      "label": "Você responderá com base em qual contexto?",
      "type": "single_choice",
      "required": true,
      "answers": [
        {
          "label": "Casa/rotina familiar",
          "value": "casa",
          "maps_to_respondent": "responsavel"
        },
        {
          "label": "Escola/sala de aula",
          "value": "escola",
          "maps_to_respondent": "professor"
        },
        {
          "label": "Atendimento ou acompanhamento complementar",
          "value": "complementar",
          "maps_to_respondent": "professor",
          "use_as": "complementary_only"
        }
      ]
    }
  ],
  "response_acceptance_rules": [
    {
      "id": "responsavel_pode_iniciar",
      "condition": "informant_group == responsavel_familiar AND can_accept_consent == true",
      "accepted": true,
      "score_role": "primary_home",
      "confidence_modifier": "standard",
      "next_step": "Aplicar SNAP-IV 26 versão responsável e solicitar formulário da escola quando possível."
    },
    {
      "id": "cuidador_pode_responder_com_confirmacao",
      "condition": "informant_group == cuidador_rotina",
      "accepted": true,
      "score_role": "primary_home_if_no_parent_available",
      "confidence_modifier": "slightly_decrease",
      "next_step": "Exigir confirmação/autorização de responsável legal antes de exibir resultado final ou compartilhar dados."
    },
    {
      "id": "professor_responde_com_autorizacao",
      "condition": "informant_group == profissional_escola",
      "accepted": true,
      "score_role": "primary_school",
      "confidence_modifier": "standard",
      "next_step": "Pontuar como ambiente escolar e combinar com resposta do responsável."
    },
    {
      "id": "informante_complementar_nao_substitui_principal",
      "condition": "informant_group == informante_complementar",
      "accepted": true,
      "score_role": "complementary",
      "confidence_modifier": "do_not_increase_without_primary_informant",
      "next_step": "Usar como complemento; solicitar responsável e professor quando possível."
    },
    {
      "id": "contato_raro_nao_classificar",
      "condition": "has_regular_contact == rarely",
      "accepted": false,
      "score_role": "none",
      "confidence_modifier": "invalid",
      "next_step": "Solicitar outro informante que conviva com a criança/adolescente."
    },
    {
      "id": "observacao_menor_4_semanas",
      "condition": "observation_period == less_than_4_weeks",
      "accepted": true,
      "score_role": "limited",
      "confidence_modifier": "decrease",
      "next_step": "Permitir rastreio inicial, mas marcar confiança baixa/moderada e recomendar nova coleta após maior período de observação."
    }
  ],
  "multi_informant_combination_rules": [
    {
      "id": "ideal_responsavel_e_professor",
      "condition": "has_primary_home == true AND has_primary_school == true",
      "confidence_level": "maior",
      "interpretation": "Melhor cenário de rastreio: informações de casa e escola permitem avaliar consistência entre ambientes."
    },
    {
      "id": "apenas_responsavel",
      "condition": "has_primary_home == true AND has_primary_school == false",
      "confidence_level": "moderada",
      "classification_cap_reference": "tdah_tod_cutoffs.maximum_classification_caps.apenas_um_informante_sem_prejuizo_importante",
      "interpretation": "Resultado útil para rastreio inicial, mas deve solicitar formulário escolar para maior precisão."
    },
    {
      "id": "apenas_professor",
      "condition": "has_primary_home == false AND has_primary_school == true",
      "confidence_level": "moderada",
      "classification_cap_reference": "tdah_tod_cutoffs.maximum_classification_caps.apenas_um_informante_sem_prejuizo_importante",
      "interpretation": "Resultado útil para alerta escolar, mas deve ser complementado por responsável antes de orientar família com resultado final."
    },
    {
      "id": "discordancia_entre_casa_e_escola",
      "condition": "major_informant_disagreement == true",
      "confidence_level": "baixa",
      "interpretation": "Diferenças entre casa e escola são clinicamente relevantes; investigar contexto, exigências ambientais, sono, ansiedade, aprendizagem, bullying e dinâmica familiar."
    },
    {
      "id": "mesmo_dominio_em_dois_ambientes",
      "condition": "same_domain_relevant_in_two_settings == true",
      "confidence_level": "maior",
      "classification_floor_reference": "tdah_tod_cutoffs.minimum_classification_floors.mesmo_dominio_relevante_em_casa_e_escola",
      "interpretation": "Sinais relevantes no mesmo domínio em casa e escola aumentam a consistência do rastreio."
    }
  ],
  "permission_rules": {
    "consent_required_before_screening": true,
    "who_can_consent": [
      "mae",
      "pai",
      "responsavel_legal"
    ],
    "who_can_receive_family_result": [
      "mae",
      "pai",
      "responsavel_legal"
    ],
    "school_result_sharing": {
      "default": "blocked",
      "allowed_only_with_responsible_authorization": true,
      "share_only_minimum_necessary": true,
      "recommended_content": [
        "orientacao_de_encaminhamento",
        "necessidade_de_observacao_escolar",
        "sugestao_de_acompanhamento_pedagogico",
        "sem_rotulo_diagnostico"
      ]
    },
    "minor_privacy_note": "Dados de criança/adolescente exigem cuidado reforçado, consentimento do responsável e linguagem sem rótulo diagnóstico."
  },
  "routing_rules": [
    {
      "id": "selecionar_versao_responsavel",
      "condition": "allowed_question_respondent_type == responsavel",
      "question_filter": {
        "respondent_contains": "responsavel"
      }
    },
    {
      "id": "selecionar_versao_professor",
      "condition": "allowed_question_respondent_type == professor",
      "question_filter": {
        "respondent_contains": "professor"
      }
    },
    {
      "id": "solicitar_escola_apos_responsavel",
      "condition": "home_screening_completed == true AND school_screening_missing == true",
      "action": "Gerar convite/formulário para professor ou escola, mediante autorização do responsável."
    },
    {
      "id": "solicitar_responsavel_apos_escola",
      "condition": "school_screening_completed == true AND home_screening_missing == true",
      "action": "Solicitar preenchimento por mãe, pai ou responsável legal antes de resultado final para família."
    }
  ],
  "quality_flags": [
    {
      "id": "informante_sem_convivio_suficiente",
      "condition": "has_regular_contact IN [monthly, rarely]",
      "effect": "decrease_confidence_or_reject",
      "message_key": "informante_nao_tem_convivio_suficiente"
    },
    {
      "id": "observacao_curta",
      "condition": "observation_period == less_than_4_weeks",
      "effect": "decrease_confidence",
      "message_key": "periodo_de_observacao_curto"
    },
    {
      "id": "sem_informante_escolar",
      "condition": "has_primary_school == false",
      "effect": "request_school_form",
      "message_key": "solicitar_formulario_escola"
    },
    {
      "id": "sem_informante_responsavel",
      "condition": "has_primary_home == false",
      "effect": "request_responsible_form",
      "message_key": "solicitar_formulario_responsavel"
    },
    {
      "id": "possivel_viés_por_conflito",
      "condition": "informant_reports_active_family_or_school_conflict == true",
      "effect": "contextualize_result",
      "message_key": "avaliar_contexto_de_conflito"
    }
  ],
  "output_schema": {
    "informant_session": {
      "informant_type": "mae | pai | responsavel_legal | avo_ou_familiar_cuidador | cuidador_principal | professor_regente | professor_disciplina | coordenador_orientador_escolar | psicologo_pedagogo_escolar",
      "informant_group": "responsavel_familiar | cuidador_rotina | profissional_escola | informante_complementar",
      "environment": "casa | escola | complementar",
      "allowed_question_respondent_type": "responsavel | professor",
      "can_accept_consent": "boolean",
      "requires_responsible_authorization": "boolean",
      "requires_responsible_confirmation": "boolean",
      "clinical_weight": "number",
      "data_confidence": "alta | moderada_alta | moderada | complementar",
      "quality_flags": [
        "string"
      ],
      "score_role": "primary_home | primary_school | primary_home_if_no_parent_available | complementary | limited | none"
    }
  },
  "implementation_notes": [
    "O app deve iniciar preferencialmente por mãe, pai ou responsável legal.",
    "Professor deve responder versão escolar mediante autorização do responsável.",
    "Cuidador pode responder se convive frequentemente, mas não deve substituir consentimento do responsável legal.",
    "Informante complementar melhora contexto, mas não aumenta confiança como casa + escola.",
    "Para TDAH/TOD, a maior confiança vem da combinação entre responsável e professor.",
    "Nunca exibir ao professor frase diagnóstica; usar linguagem de observação e encaminhamento.",
    "Quando só houver um informante, o resultado deve ser classificado como rastreio inicial e solicitar o outro ambiente."
  ]
}
