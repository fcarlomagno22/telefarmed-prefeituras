EXPO_PUBLIC_LOGO_URL=assets/logo.png
EXPO_PUBLIC_BACKGROUND_IMAGE_URL=assets/fundo_login.png
EXPO_PUBLIC_MUNICIPALITY_NAME=São Paulo
# URLs separadas por vírgula ou JSON: ["https://.../banner1.jpg","https://.../banner2.jpg"]
EXPO_PUBLIC_PROMO_BANNERS=
# Subdomínio do Ready Player Me (use "demo" para testes)
EXPO_PUBLIC_RPM_SUBDOMAIN=demo
# Compartilhamento ao vivo entre dispositivos (Supabase)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Em dev, o app detecta sozinho http://SEU_IP:5173 via Metro (porta do Vite).
# Só defina se quiser forçar outra URL:
# EXPO_PUBLIC_LIVE_SHARE_WEB_BASE_URL=http://192.168.1.103:5173
# EXPO_PUBLIC_LIVE_SHARE_WEB_PORT=5173
