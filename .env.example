# API REST (proxy Vite: /api/v1 → http://localhost:3001/api/v1)
VITE_API_BASE_URL=/api/v1
# VITE_USE_MOCK_API=true

# Segredos do servidor (JWT, Supabase, etc.) → backend/.env

# LiveKit Cloud (teleconsulta — URL pública WebSocket, sem segredos)
VITE_LIVEKIT_URL=wss://seu-projeto.livekit.cloud

VITE_BRAND_COLOR=#ff6b00
VITE_LOGO_URL=/logo_4.png
# Imagem de fundo do painel esquerdo (URL absoluta ou caminho em /public)
VITE_BACKGROUND_IMAGE_URL=/fundo_login.png

# Imagem de fundo do login da prefeitura
VITE_PREFEITURA_BACKGROUND_IMAGE_URL=/fundo_login_pref.png

# Imagem de fundo do login do painel admin
VITE_ADMIN_BACKGROUND_IMAGE_URL=/fundo_painel_admin.png

# Textos da marca
VITE_APP_NAME=Telefarmed
VITE_APP_TAGLINE=Farmácia e Telemedicina
VITE_HEADLINE=Cuidado que te acompanha. Saúde que te conecta.
VITE_SUBHEADLINE=Gestão inteligente para uma saúde pública mais próxima, humana e eficiente.
VITE_WELCOME_TITLE=Bem-vindo ao Painel Operacional da Unidade
VITE_WELCOME_SUBTITLE=Acesse com seu usuário para continuar
VITE_COPYRIGHT=© 2025 Telefarmed. Todos os direitos reservados.

# Operador logado (footer flutuante — UBT)
VITE_OPERATOR_NAME=Juliana Silva
VITE_OPERATOR_ROLE=Funcionário público · responsável pelo Terminal
VITE_OPERATOR_FOOTER_LABEL=Operador logado

# Operador logado (footer — painel prefeitura /prefeitura)
VITE_PREFEITURA_OPERATOR_NAME=Orlando Santos
VITE_PREFEITURA_OPERATOR_ROLE=Secretário de Saúde
VITE_PREFEITURA_OPERATOR_FOOTER_LABEL=Operador logado

# Home (Terminal único — um paciente por vez)
VITE_DASHBOARD_TITLE=Terminal de atendimento da unidade
VITE_DASHBOARD_SUBTITLE=Um paciente por vez neste computador
VITE_DASHBOARD_STATION_TITLE=Atendimento por telemedicina
VITE_DASHBOARD_STATION_IDLE_HINT=Chame o próximo paciente, confira os dados e inicie o atendimento. Enquanto houver consulta ativa, este Terminal fica reservado para essa pessoa.
VITE_DASHBOARD_FLOW_IMAGE_URL=/fluxo.png
VITE_DASHBOARD_AGE_IMAGE_URL=/age.png
VITE_DASHBOARD_SPECIALTY_IMAGE_URL=/especialidade.png
